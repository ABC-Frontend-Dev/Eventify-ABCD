// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Model {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Clients {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  image       String
}
model ProjectCategory {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  project     Project[]
}

model Project {
  id          Int             @id @default(autoincrement())
  title       String
  description String
  bannerImage String
  categoryId  Int
  hasTabs     Boolean         @default(false)  // Toggle for tabs
  tabs        ProjectTab[]    // Relation to tabs
  images      String[]        // Images if no tabs
  category    ProjectCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

model ProjectTab {
  id        Int      @id @default(autoincrement())
  name      String   // Tab name (e.g., "Interior", "Exterior", "Gallery")
  images    String[] // Array of image URLs for this tab
  order     Int      @default(0) // Display order
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Author {
  id     Int     @id @default(autoincrement())
  name   String
  bio    String?
  email  String  @unique
  avatar String?
  blogs  Blog[]
}

model BlogCategory {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  blogs       Blog[]
}

model Blog {
  id              Int          @id @default(autoincrement())
  title           String       @db.VarChar(100)
  slug            String       @unique @db.VarChar(100)
  description     String       @db.VarChar(160)
  content         String
  metaTitle       String       @db.VarChar(60)
  keywords        String[]
  thumbnail       String
  banner_image    String
  canonical       String
  timeToRead      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  authorId        Int
  categoryId      Int
  schemaScript    String
  metaDescription String       @db.VarChar(160)
  publishedAt     DateTime?
  status          BlogStatus   @default(DRAFT)
  author          Author       @relation(fields: [authorId], references: [id])
  category        BlogCategory @relation(fields: [categoryId], references: [id])

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id          Int                    @id @default(autoincrement())
  name        String
  email       String
  phone       String
  message     String                 @db.Text
  status      ContactSubmissionStatus @default(NEW)
  submittedAt DateTime               @default(now())
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([status])
  @@index([submittedAt])
}

enum ContactSubmissionStatus {
  NEW
  READ
}

model Service {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  image       String
  url         String    @unique
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([order])
}

// Add this to your existing schema.prisma

model Award {
  id          Int            @id @default(autoincrement())
  year        Int
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  categories  AwardCategory[]

  @@unique([year]) // One award per year
  @@index([year])
}

model AwardCategory {
  id                Int           @id @default(autoincrement())
  name              String        // e.g., "WOW Awards Middle East"
  icon              String        // Icon URL
  iconAlt           String        // Alt text for icon
  order             Int           @default(0)
  gradientWidthClass String       @default("w-4/5") // CSS class for gradient width
  awardId           Int
  award             Award         @relation(fields: [awardId], references: [id], onDelete: Cascade)
  carouselImages    AwardCarouselImage[]
  items             AwardItem[]

  @@index([awardId])
}

model AwardCarouselImage {
  id          Int            @id @default(autoincrement())
  url         String
  order       Int            @default(0)
  categoryId  Int
  category    AwardCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model AwardItem {
  id          Int            @id @default(autoincrement())
  title       String
  description String
  order       Int            @default(0)
  categoryId  Int
  category    AwardCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model Comparison {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  beforeImage String
  afterImage  String
  order       Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  position  Int      @unique // 1-35, matches the fixed grid slot on the Teams page
  name      String
  role      String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}